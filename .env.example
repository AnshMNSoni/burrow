# Burrow Environment Configuration
# Copy this file to .env and fill in your values.

# ── Core ──────────────────────────────────────────────────────────────────────
BURROW_LOG_LEVEL=info
BURROW_LLM_PROVIDER=mock
BURROW_LLM_API_KEY=
BURROW_PROJECT_ROOT=.

# ── FastAPI Server ─────────────────────────────────────────────────────────────
BURROW_API_HOST=127.0.0.1
BURROW_API_PORT=8000

# ── Ollama LLM ─────────────────────────────────────────────────────────────────
BURROW_OLLAMA_ENDPOINT=http://localhost:11434
BURROW_OLLAMA_MODEL=qwen2.5-coder
# Timeout (seconds) for each Ollama HTTP request — increase on slow hardware
BURROW_OLLAMA_TIMEOUT=30.0
# Number of retry attempts before falling back to static analysis
BURROW_OLLAMA_MAX_RETRIES=2

# ── Auto Patch ─────────────────────────────────────────────────────────────────
BURROW_ENABLE_AUTO_PATCH=false
BURROW_PATCH_MIN_CONFIDENCE=0.70
# Comma-separated subdirectories to restrict patch writes (empty = whole workspace)
BURROW_ALLOWED_WRITE_PATHS=

# ── Performance & Caching ──────────────────────────────────────────────────────
# Max number of AnalysisResult entries to cache in memory
BURROW_CACHE_SIZE=10
# Cache time-to-live in seconds (same trace re-submitted within TTL returns cached result)
BURROW_CACHE_TTL=60.0
# Workspace re-scan cooldown (seconds) — avoids redundant full directory walks
BURROW_SCAN_TTL=30.0
# Max source files to parse during workspace scan (raise for monorepos)
BURROW_MAX_SCAN_FILES=300
# Max nodes in the symbol dependency graph (cap to keep graph operations fast)
BURROW_MAX_GRAPH_NODES=5000
# Max characters in a single /api/v1/analyze request payload
BURROW_MAX_REQUEST_SIZE=50000
