# Burrow Environment Configuration

# Log level: debug, info, warning, error
BURROW_LOG_LEVEL=info

# LLM config (mock, ollama, openai, etc.)
BURROW_LLM_PROVIDER=mock
BURROW_LLM_API_KEY=

# Default project root for resolving file paths
BURROW_PROJECT_ROOT=.

# FastAPI Server settings
BURROW_API_HOST=127.0.0.1
BURROW_API_PORT=8000
