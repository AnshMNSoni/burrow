{
  "name": "burrow",
  "displayName": "Burrow",
  "description": "Local-first AI debugging intelligence extension",
  "version": "0.1.0",
  "publisher": "ansh",
  "engines": {
    "vscode": "^1.89.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Debuggers"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "burrow.analyzeSelection",
        "title": "Burrow: Analyze Selection"
      },
      {
        "command": "burrow.analyzeFile",
        "title": "Burrow: Analyze Active File"
      },
      {
        "command": "burrow.startBackend",
        "title": "Burrow: Start API Backend"
      },
      {
        "command": "burrow.stopBackend",
        "title": "Burrow: Stop API Backend"
      },
      {
        "command": "burrow.clearDiagnostics",
        "title": "Burrow: Clear Diagnostics"
      },
      {
        "command": "burrow.previewPatch",
        "title": "Burrow: Preview Patch"
      },
      {
        "command": "burrow.applyPatch",
        "title": "Burrow: Apply Patch"
      },
      {
        "command": "burrow.explainMore",
        "title": "Burrow: Explain Last Analysis"
      },
      {
        "command": "burrow.openFile",
        "title": "Burrow: Open File"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "burrow.analyzeSelection",
          "group": "navigation",
          "when": "editorHasSelection"
        },
        {
          "command": "burrow.analyzeFile",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "burrow-sidebar",
          "title": "Burrow",
          "icon": "$(bug)"
        }
      ]
    },
    "views": {
      "burrow-sidebar": [
        {
          "id": "burrow.analysisView",
          "name": "Burrow Ingest & Diagnostics",
          "type": "tree"
        }
      ]
    },
    "configuration": {
      "title": "Burrow Settings",
      "properties": {
        "burrow.backendUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "Base URL of the Burrow FastAPI backend API."
        },
        "burrow.autoStartBackend": {
          "type": "boolean",
          "default": true,
          "description": "Automatically spawn and manage the lifecycle of the Python FastAPI backend."
        },
        "burrow.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Path or command name for the Python executable (e.g. python, python3, .venv/bin/python)."
        },
        "burrow.logLevel": {
          "type": "string",
          "default": "INFO",
          "enum": [
            "DEBUG",
            "INFO",
            "WARNING",
            "ERROR"
          ],
          "description": "Logging level for the background FastAPI backend server."
        },
        "burrow.enableAutoPatch": {
          "type": "boolean",
          "default": false,
          "description": "Allow non-interactive patch application (requires explicit trust check)."
        },
        "burrow.patchMinConfidence": {
          "type": "number",
          "default": 0.70,
          "description": "Minimum patch confidence score threshold to suggest or auto-apply fixes."
        },
        "burrow.allowedWritePaths": {
          "type": "string",
          "default": "",
          "description": "Comma-separated list of directories relative to workspace root permitted for patch writes (leave empty to allow whole workspace)."
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.89.0",
    "typescript": "^5.3.3"
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  }
}
